# Playwright prod smoke suite (D9 step-8) — copy to .env.test (gitignored) and fill.
# These are the STAFF login the owner created in Settings → Staff (show-once creds).
# NEVER commit real values. .env.test is gitignored; this .example is the template.
PW_STAFF_EMAIL=<name>.<4digits>@<clubslug>.ck.local
PW_STAFF_PASSWORD=<the show-once password>

# Optional: override the deployed target (defaults to https://app.handbookhq.in).
# PW_BASE_URL=https://<preview-deploy>.vercel.app
